{
  "name": "cursor-show",
  "version": "1.0.0",
  "description": "System cursor overlay — shows cursor when game hides it",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "40.8.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.crintech.cursor-show",
    "productName": "Cursor Show",
    "win": {
      "target": "nsis",
      "icon": "icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    }
  }
}
